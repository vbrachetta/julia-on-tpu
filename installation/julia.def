Bootstrap: docker
From: julia:1.12.5

%post
    export JULIA_DEPOT_PATH=/opt/julia_depot
    mkdir -p /opt/julia_depot
    julia -e '
        using Pkg
        Pkg.add(["Reactant", "Enzyme", "BenchmarkTools", "BFloat16s"])
        Pkg.precompile()
    '

%environment
    export JULIA_DEPOT_PATH=/opt/julia_depot
    export JULIA_HISTORY="$HOME/.julia_history"
